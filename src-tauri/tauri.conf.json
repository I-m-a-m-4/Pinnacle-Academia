{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pinnacle-academia",
  "version": "0.0.1",
  "identifier": "com.pinnacleacademia.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:9007",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pinnacle Academia v0.0.1",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: https: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.paystack.co; connect-src 'self' https: wss: blob:; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": true,
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/I-m-a-m-4/Pinnacle-Academia/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREQTAyQjM4QTk1MkI4QgpSV1NMSzVXS3N3TGFCTWdnUVdWM2FhVnZoaG9DaHlWaTZnK1V1WHBIcm9leTl2ZkduUGNnUndicwo="
    }
  }
}
