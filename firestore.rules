// Force rules update - Version 2.0.7
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================================================
    // Helper Functions
    // =================================================================
    
    function isSuperAdmin() {
      return request.auth != null && 
             (request.auth.uid == 'jzQgCHzaObeUbeYklTLtQQh03G53' || 
              (request.auth.token != null && 'email' in request.auth.token && request.auth.token.email == 'belloimam431@gmail.com'));
    }

    match /{allPaths=**} {
      allow read, write: if isSuperAdmin();
    }

    function isUserAuthenticated() {
      return request.auth != null;
    }

    // Direct access to user profile data - cached within a single request
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : {};
    }

    function getCurrentUserBusinessId() {
      return isUserAuthenticated() ? getUserData().get('businessId', 'none') : 'none';
    }

    function getCurrentUserRole() {
      return isUserAuthenticated() ? getUserData().get('role', 'none') : 'none';
    }

    function isRequestingUserMemberOf(businessId) {
      return isSuperAdmin() || (isUserAuthenticated() && getCurrentUserBusinessId() == businessId);
    }
    
    function isRequestingUserAdmin() {
      return isSuperAdmin() || (isUserAuthenticated() && getCurrentUserRole() in ['admin', 'owner', 'super-admin']);
    }

    function isRequestingUserManager() {
      return isSuperAdmin() || (isUserAuthenticated() && getCurrentUserRole() in ['admin', 'manager', 'owner', 'super-admin']);
    }

    function isRequestingUserStaff() {
      return isSuperAdmin() || (isUserAuthenticated() && getCurrentUserRole() in ['admin', 'manager', 'owner', 'super-admin', 'operator', 'staff', 'vendor_operator']);
    }

    function isSubscriptionActive(businessId) {
      return isSuperAdmin() || 
             (exists(/databases/$(database)/documents/businessInstances/$(businessId)) && 
              get(/databases/$(database)/documents/businessInstances/$(businessId)).data.get('status', 'active') in ['active', 'trialing']);
    }

    function hasPermission(permission) {
      return isSuperAdmin() || 
             getUserData().get('permissions', {}).get(permission, true) != false;
    }

    // =================================================================
    // Public & Admin-Only Collections
    // =================================================================

    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /notifications/{notificationId} {
      allow list, get: if isUserAuthenticated();
      allow create, delete: if isSuperAdmin();
      allow update: if false;
    }
   
    match /purchases/{purchaseId} {
      allow create: if isUserAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow read, list: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /supportThreads/{threadId} {
        allow read: if isSuperAdmin() || (isUserAuthenticated() && resource.data.userId == request.auth.uid);
        allow create: if isUserAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update: if isSuperAdmin();

        match /messages/{messageId} {
            allow create: if isSuperAdmin() || (isUserAuthenticated() && get(/databases/$(database)/documents/supportThreads/$(threadId)).data.userId == request.auth.uid);
            allow read: if isSuperAdmin() || (isUserAuthenticated() && get(/databases/$(database)/documents/supportThreads/$(threadId)).data.userId == request.auth.uid);
        }
    }

    // =================================================================
    // Multi-Tenant Collections
    // =================================================================

    match /businessInstances/{businessId} {
      allow get: if true;
      
      allow list: if (isUserAuthenticated() && request.query.limit <= 1) || isSuperAdmin();
      
      allow create: if isUserAuthenticated() && request.auth.uid == request.resource.data.ownerId;
      allow update: if isSuperAdmin() || (isUserAuthenticated() && isRequestingUserAdmin() && isRequestingUserMemberOf(businessId)) || 
                      (isUserAuthenticated() && resource.data.get('ownerId', null) == request.auth.uid);
      allow delete: if isSuperAdmin();
      
      match /subscription_history/{historyId} {
        allow read, list: if isSuperAdmin() || (isUserAuthenticated() && isRequestingUserMemberOf(businessId));
        allow create: if isUserAuthenticated();
        allow update, delete: if false;
      }

      match /auditLogs/{logId} {
        allow list, get: if isSuperAdmin() || (isUserAuthenticated() && isRequestingUserAdmin() && isRequestingUserMemberOf(businessId));
        allow create: if isUserAuthenticated();
        allow update, delete: if false;
      }

      match /onlineOrders/{orderId} {
         allow read, list: if isSuperAdmin() || (isUserAuthenticated() && isRequestingUserMemberOf(businessId));
         allow create: if true; 
         allow update: if isSuperAdmin() || (isUserAuthenticated() && isRequestingUserMemberOf(businessId));
         allow delete: if false;
      }

      match /stats/{statId} {
        allow read, write: if isSuperAdmin() || 
                             (isUserAuthenticated() && (
                               getCurrentUserBusinessId() == businessId || 
                               get(/databases/$(database)/documents/businessInstances/$(businessId)).data.ownerId == request.auth.uid
                             ));
      }
    }

    match /users/{userId} {
      allow get: if isSuperAdmin() || (isUserAuthenticated() && request.auth.uid == userId);
      allow list: if isSuperAdmin() || (isUserAuthenticated() && getCurrentUserBusinessId() == resource.data.businessId);
      allow update: if isSuperAdmin() || 
                       (isUserAuthenticated() && request.auth.uid == userId) ||
                       (isRequestingUserAdmin() && isRequestingUserMemberOf(resource.data.get('businessId', 'none')));
      allow create: if isUserAuthenticated() && request.auth.uid == userId;
      allow delete: if isSuperAdmin();
      
      match /notifications/{notificationId} {
        allow read: if isSuperAdmin() || (isUserAuthenticated() && request.auth.uid == userId);
        allow write: if isSuperAdmin() || 
                        (isUserAuthenticated() && (
                          request.auth.uid == userId || 
                          (isRequestingUserAdmin() && isRequestingUserMemberOf(get(/databases/$(database)/documents/users/$(userId)).data.get('businessId', 'none')))
                        ));
      }

      match /fcmTokens/{tokenId} {
        allow read, write: if isSuperAdmin() || (isUserAuthenticated() && request.auth.uid == userId);
      }

      match /sessions/{sessionId} {
        allow read, write: if isSuperAdmin() || (isUserAuthenticated() && request.auth.uid == userId);
      }
    }
   
    match /invitations/{invitationId} {
      allow read: if true; 
      allow create: if isSuperAdmin() || (isUserAuthenticated() && isRequestingUserAdmin());
      allow list: if isSuperAdmin() || isUserAuthenticated();
      allow delete: if isSuperAdmin() || (isUserAuthenticated() && isRequestingUserAdmin() && isRequestingUserMemberOf(resource.data.businessId));
    }

    match /products/{productId} {
      allow get: if isSuperAdmin() || (isUserAuthenticated() && (resource == null || isRequestingUserMemberOf(resource.data.get('businessId', null))));
      allow list: if isSuperAdmin() || (isUserAuthenticated() && (resource.data.get('businessId', 'none') == getCurrentUserBusinessId() || resource.data.get('createdBy', null) == request.auth.uid));
      
      allow create: if isSuperAdmin() || (isUserAuthenticated() && 
                      isRequestingUserStaff() && 
                      hasPermission('manage_inventory') &&
                      isRequestingUserMemberOf(request.resource.data.get('businessId', null)) && 
                      isSubscriptionActive(request.resource.data.get('businessId', null)));
      allow update: if isSuperAdmin() || (isUserAuthenticated() && 
                      isRequestingUserStaff() && 
                      isRequestingUserMemberOf(resource.data.get('businessId', null)) && 
                      isSubscriptionActive(resource.data.get('businessId', null)) &&
                      (
                        hasPermission('manage_inventory') ||
                        (hasPermission('record_sales') && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'updatedAt']))
                      ));
      allow delete: if isSuperAdmin() || (isUserAuthenticated() && (resource == null || (
                      isRequestingUserManager() && 
                      hasPermission('manage_inventory') &&
                      isRequestingUserMemberOf(resource.data.get('businessId', null)) && 
                      isSubscriptionActive(resource.data.get('businessId', null)))));
    }

    match /receipts/{receiptId} {
        allow get: if true;
        allow list: if isSuperAdmin() || (isUserAuthenticated() && (resource.data.get('businessId', 'none') == getCurrentUserBusinessId() || resource.data.get('createdBy', null) == request.auth.uid));
        
        allow create: if isSuperAdmin() || (isUserAuthenticated() && 
                        isRequestingUserMemberOf(request.resource.data.get('businessId', null)) && 
                        hasPermission('record_sales') &&
                        isSubscriptionActive(request.resource.data.get('businessId', null)));
        allow update: if isSuperAdmin() || (isUserAuthenticated() && 
                                isRequestingUserManager() && 
                                hasPermission('record_sales') &&
                                isRequestingUserMemberOf(resource.data.get('businessId', null)) && 
                                isSubscriptionActive(resource.data.get('businessId', null)));
        allow delete: if isSuperAdmin() || (isUserAuthenticated() && (resource == null || (
                                isRequestingUserManager() && 
                                hasPermission('record_sales') &&
                                isRequestingUserMemberOf(resource.data.get('businessId', null)) && 
                                isSubscriptionActive(resource.data.get('businessId', null)))));
    }
    
    match /customers/{customerId} {
      allow get: if isSuperAdmin() || (isUserAuthenticated() && (resource == null || isRequestingUserMemberOf(resource.data.get('businessId', null)) || resource.data.get('createdBy', null) == request.auth.uid));
      allow list: if isSuperAdmin() || (isUserAuthenticated() && (resource.data.get('businessId', 'none') == getCurrentUserBusinessId() || resource.data.get('createdBy', null) == request.auth.uid));
      
      allow create: if isUserAuthenticated() && hasPermission('view_customers'); 
      allow update: if isSuperAdmin() || (isUserAuthenticated() && 
                      isRequestingUserStaff() && 
                      isRequestingUserMemberOf(resource.data.get('businessId', null)) && 
                      isSubscriptionActive(resource.data.get('businessId', null)) &&
                      (
                        hasPermission('view_customers') ||
                        (hasPermission('record_sales') && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalSpent', 'loyaltyPoints', 'updatedAt']))
                      ));
      allow delete: if isSuperAdmin() || (isUserAuthenticated() && (resource == null || (
                      isRequestingUserManager() && 
                      hasPermission('view_customers') &&
                      isRequestingUserMemberOf(resource.data.get('businessId', null)) && 
                      isSubscriptionActive(resource.data.get('businessId', null)))));
    }

    match /admin_analytics/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /system_broadcasts/{broadcastId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /{path=**}/auditLogs/{logId} {
      allow read, list: if isSuperAdmin();
      allow create: if isUserAuthenticated();
    }

    match /follow_up_logs/{logId} {
      allow read, list, write: if isSuperAdmin();
    }
  }
}
